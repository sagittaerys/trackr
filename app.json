{
  "expo": {
    "name": "Trackr",
    "slug": "trackr",
    "scheme": "trackr",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.trackr.app",
      "adaptiveIcon": {
        "backgroundColor": "#1B3FA0"
      }
    },
    "ios": {
      "bundleIdentifier": "com.trackr.app",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Trackr needs camera access for liveness verification"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}